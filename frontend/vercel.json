{
  "headers": [
    {
      "source": "/.well-known/security.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/.well-known/security.txt",
      "destination": "/.well-known/security.txt"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
